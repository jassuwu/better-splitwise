{
  "name": "better-splitwise",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:mobile": "turbo run dev --filter=mobile",
    "dev:web": "turbo run dev --filter=web",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "tc": "turbo run check-types",
    "test": "turbo run test",
    "test:core": "turbo run test --filter=./packages/*"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.18",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": {
    "packages": ["apps/*", "packages/*"],
    "catalog": {
      "drizzle-orm": "^0.45.2",
      "typescript": "5.9.2",
      "vitest": "^4.1.9",
      "zod": "^4.4.3"
    }
  }
}
