---
import Layout from "../layouts/Layout.astro";

const REPO = "https://github.com/jassuwu/better-splitwise";
const RELEASES = `${REPO}/releases/latest`;
const TWITTER = "https://x.com/jassdotgg";

const points = [
  {
    title: "only what i want to see",
    body: "who you owe, who owes you. no activity feed, no ads, no nudges, no upsell.",
  },
  {
    title: "equal or by item",
    body: "add an expense and split it the way the bill actually went — evenly, or line by line. one clean push to splitwise.",
  },
  {
    title: "no one to convince",
    body: "it's a client over the splitwise your friends already use. nothing to migrate, no new app to nag anyone into installing.",
  },
];
---

<Layout>
  <main class="mx-auto flex min-h-dvh max-w-2xl flex-col px-6">
    <!-- hero -->
    <section class="pt-24 pb-12">
      <img src="/favicon.svg" alt="" width="56" height="56" class="mb-8 size-14" />

      <h1 class="font-display text-5xl font-extrabold tracking-tight sm:text-6xl">
        <span class="text-lime">better</span> splitwise
      </h1>

      <p class="mt-5 max-w-xl text-lg leading-relaxed text-muted sm:text-xl">
        a simpler splitwise client — it shows me only what i want to see: who i
        owe, and who owes me. i add an expense, split it equally or by item, and
        that's it.
      </p>

      <div class="mt-9 flex flex-wrap items-center gap-3">
        <a
          href={RELEASES}
          class="rounded-full bg-lime px-5 py-2.5 text-sm font-semibold text-[#0a0a0a] transition hover:opacity-90"
        >
          get it on android
        </a>
        <a
          href={REPO}
          class="rounded-full border border-line px-5 py-2.5 text-sm font-medium text-ink transition hover:border-white/25"
        >
          view source
        </a>
      </div>

      <p class="mt-4 text-sm text-muted">
        ios — coming. for now, you can build it from source.
      </p>
    </section>

    <!-- the reel -->
    <section class="pb-16">
      <figure>
        <video
          class="aspect-video w-full rounded-2xl border border-line bg-surface"
          controls
          playsinline
          preload="none"
          poster="/reel-poster.jpg"
        >
          <source src="/reel.mp4" type="video/mp4" />
        </video>
        <figcaption class="mt-3 text-center text-sm text-muted">
          one ₹7,400 dinner, split to the cent. press play — 28 seconds, sound on.
        </figcaption>
      </figure>
    </section>

    <!-- why -->
    <section class="border-t border-line py-14">
      <ul class="grid gap-8 sm:grid-cols-3">
        {
          points.map((p) => (
            <li>
              <h2 class="font-display text-base font-semibold text-ink">
                {p.title}
              </h2>
              <p class="mt-2 text-sm leading-relaxed text-muted">{p.body}</p>
            </li>
          ))
        }
      </ul>
    </section>

    <!-- a client for me -->
    <section class="border-t border-line py-12">
      <p class="max-w-xl text-base leading-relaxed text-muted">
        it's a client i built for myself. if you find it useful too, tell me —
        <a
          href={TWITTER}
          class="text-lime underline-offset-4 hover:underline">@jassdotgg</a
        >.
      </p>
    </section>

    <!-- footer -->
    <footer
      class="mt-auto flex flex-wrap items-center justify-between gap-4 border-t border-line py-8 text-sm text-muted"
    >
      <p>not affiliated with splitwise.</p>
      <nav class="flex items-center gap-5">
        <a href={REPO} class="transition hover:text-ink">github</a>
        <a href={TWITTER} class="transition hover:text-ink">twitter</a>
        <a href="https://jass.gg" class="transition hover:text-ink">jass.gg</a>
        <span class="opacity-60">mit</span>
      </nav>
    </footer>
  </main>
</Layout>
