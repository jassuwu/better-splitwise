{
  "expo": {
    "name": "better splitwise",
    "slug": "better-splitwise",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bettersplitwise",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "gg.jass.bettersplitwise"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0c0e12",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.bettersplitwise"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0c0e12",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "better splitwise reads receipt photos you pick so it can itemize a bill.",
          "cameraPermission": "better splitwise uses the camera to scan receipts."
        }
      ],
      "expo-quick-actions"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
